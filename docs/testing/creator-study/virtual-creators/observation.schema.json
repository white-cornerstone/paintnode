{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paintnode.com/schemas/virtual-creator-observation-v1.json",
  "title": "PaintNode virtual creator observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordType",
    "syntheticOnly",
    "sessionId",
    "profileId",
    "build",
    "agentTask",
    "lifecycle",
    "tasks",
    "findings",
    "ownerReview",
    "limitations"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "recordType": { "const": "paintnode-virtual-creator-observation" },
    "syntheticOnly": { "const": true },
    "sessionId": { "type": "string", "pattern": "^VC-V0[1-8]-[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$" },
    "profileId": { "type": "string", "pattern": "^V0[1-8]$" },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gitSha", "bundleId", "executableSha256"],
      "properties": {
        "gitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "bundleId": { "const": "com.paintnode.editor.blueprintqa.provider.free" },
        "executableSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "agentTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["externalTaskId", "newTaskConfirmed", "noForkConfirmed"],
      "properties": {
        "externalTaskId": { "type": ["string", "null"], "minLength": 1 },
        "newTaskConfirmed": { "type": "boolean" },
        "noForkConfirmed": { "type": "boolean" }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attemptStage", "checkoutAttestations", "checkoutAttestationReceiptSha256", "setupReceiptSha256", "cleanupReceiptSha256", "setupProfileSha256", "cleanupProfileSha256", "dataStoreRemoved", "dataStoreRemovalVerified", "finalized", "cleanupReceiptRecordedAt"],
      "properties": {
        "attemptStage": { "enum": ["pending", "prelaunch", "finalized"] },
        "checkoutAttestations": { "type": "array", "maxItems": 3, "items": { "$ref": "#/$defs/checkoutAttestation" } },
        "checkoutAttestationReceiptSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "setupReceiptSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "cleanupReceiptSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "setupProfileSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "cleanupProfileSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "dataStoreRemoved": { "type": "boolean" },
        "dataStoreRemovalVerified": { "type": "boolean" },
        "finalized": { "type": "boolean" },
        "cleanupReceiptRecordedAt": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "prefixItems": [
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 1 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 2 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 3 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 4 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 5 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 6 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 7 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 8 } } }] }
      ],
      "items": false
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "ownerReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedLive", "evidenceReviewed", "decision", "selectedForAggregate", "standard", "notes", "reviewedAt"],
      "properties": {
        "observedLive": { "type": "boolean" },
        "evidenceReviewed": { "type": "boolean" },
        "decision": { "enum": ["pending", "accepted", "rejected"] },
        "selectedForAggregate": { "type": "boolean" },
        "standard": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" },
        "reviewedAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "allOf": [
        {
          "if": { "properties": { "decision": { "const": "accepted" } }, "required": ["decision"] },
          "then": {
            "properties": {
              "observedLive": { "const": true },
              "evidenceReviewed": { "const": true },
              "notes": { "type": "string", "minLength": 1 },
              "reviewedAt": { "type": "string", "format": "date-time" }
            }
          },
          "else": {
            "if": { "properties": { "decision": { "const": "rejected" } }, "required": ["decision"] },
            "then": {
              "properties": {
                "notes": { "type": "string", "minLength": 1 },
                "reviewedAt": { "type": "string", "format": "date-time" }
              }
            },
            "else": { "properties": { "reviewedAt": { "const": null }, "selectedForAggregate": { "const": false } } }
          }
        }
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "ownerReview": { "properties": { "decision": { "const": "accepted" } }, "required": ["decision"] } },
        "required": ["ownerReview"]
      },
      "then": {
        "properties": {
          "agentTask": {
            "properties": {
              "externalTaskId": { "type": "string", "minLength": 1 },
              "newTaskConfirmed": { "const": true },
              "noForkConfirmed": { "const": true }
            }
          },
          "lifecycle": {
            "properties": {
              "attemptStage": { "const": "finalized" },
              "checkoutAttestations": { "minItems": 3, "maxItems": 3 },
              "checkoutAttestationReceiptSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "setupReceiptSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "cleanupReceiptSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "setupProfileSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "cleanupProfileSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "dataStoreRemoved": { "const": true },
              "dataStoreRemovalVerified": { "const": true },
              "finalized": { "const": true },
              "cleanupReceiptRecordedAt": { "type": "string", "format": "date-time" }
            }
          },
          "ownerReview": { "properties": { "selectedForAggregate": { "const": true } } },
          "tasks": {
            "allOf": [
              { "not": { "contains": { "properties": { "outcome": { "enum": ["not-run", "failed"] } }, "required": ["outcome"] } } },
              { "not": { "contains": { "properties": { "uiEvidence": { "maxItems": 0 } }, "required": ["uiEvidence"] } } }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "checkoutAttestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "expectedGitSha", "actualGitSha", "sourceStatusSha256", "attestedAt"],
      "properties": {
        "phase": { "enum": ["fresh", "resume", "finalize"] },
        "expectedGitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "actualGitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sourceStatusSha256": { "const": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" },
        "attestedAt": { "type": "string", "format": "date-time" }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "outcome", "elapsedWallMs", "interventions", "scenarioEvents", "deviationIds", "frictionFlags", "uiEvidence", "notes"],
      "properties": {
        "task": { "type": "integer", "minimum": 1, "maximum": 8 },
        "outcome": { "enum": ["not-run", "completed-unaided", "completed-assisted", "failed"] },
        "elapsedWallMs": { "type": ["integer", "null"], "minimum": 0 },
        "interventions": {
          "type": "array",
          "items": { "$ref": "#/$defs/intervention" }
        },
        "scenarioEvents": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenarioEvent" }
        },
        "deviationIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["none", "late-timing", "verbatim-repeat", "approved-accommodation", "early-hint", "out-of-order-hint", "wording-changed", "unlogged-assist", "silent-app-state-change", "unauthorized-takeover", "calibration-missing", "instrument-version-mismatch", "instrument-hash-mismatch", "instrument-change-unapproved"] }
        },
        "frictionFlags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["discovery", "label-ambiguity", "state-ambiguity", "navigation", "error-comprehension", "recovery-scope", "keyboard-focus", "performance"] }
        },
        "uiEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      }
    },
    "intervention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "checkpointId", "eventType", "exactText", "elapsedWallMs", "assistIncrement"],
      "properties": {
        "id": { "type": "string", "pattern": "^T[1-8]-C[1-9][0-9]*-(?:NP[1-9][0-9]*|H[12]|TO|VR[1-9][0-9]*)$" },
        "checkpointId": { "type": "string", "pattern": "^T[1-8]-C[1-9][0-9]*$" },
        "eventType": { "enum": ["neutral-probe", "standard-hint", "takeover", "verbatim-repeat"] },
        "exactText": { "type": "string", "minLength": 1 },
        "elapsedWallMs": { "type": "integer", "minimum": 0 },
        "assistIncrement": { "enum": [0, 1] }
      }
    },
    "scenarioEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "scenario", "spokenText", "expectedTrigger", "observedTrigger", "elapsedWallMs"],
      "properties": {
        "action": { "enum": ["setup", "reset"] },
        "scenario": { "enum": ["Branch recovery checkpoint", "Format recovery checkpoint", "Standard checkpoint"] },
        "spokenText": { "enum": ["I am setting the test checkpoint for this task", "I am resetting the test checkpoint"] },
        "expectedTrigger": { "type": "string", "minLength": 1 },
        "observedTrigger": { "type": ["string", "null"] },
        "elapsedWallMs": { "type": "integer", "minimum": 0 }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "task", "category", "impact", "evidenceRefs", "interpretation", "requiresHumanValidation"],
      "properties": {
        "id": { "type": "string", "pattern": "^VCF-[1-9][0-9]*$" },
        "task": { "type": "integer", "minimum": 1, "maximum": 8 },
        "category": { "enum": ["data-integrity", "wrong-lineage", "accepted-direction", "editor-return", "save-reopen", "keyboard-accessibility", "critical-task-impossible", "required-input-comprehension", "copy-clarity", "navigation-discovery", "recovery-clarity", "repeated-error-burden", "performance"] },
        "impact": { "enum": ["hypothesis-high", "hypothesis-medium", "hypothesis-low", "observation"] },
        "evidenceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "interpretation": { "type": "string", "minLength": 1 },
        "requiresHumanValidation": { "const": true }
      }
    }
  }
}
