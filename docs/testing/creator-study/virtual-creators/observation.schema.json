{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paintnode.com/schemas/virtual-creator-observation-v1.json",
  "title": "PaintNode virtual creator observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordType",
    "syntheticOnly",
    "sessionId",
    "profileId",
    "build",
    "tasks",
    "findings",
    "ownerReview",
    "limitations"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "recordType": { "const": "paintnode-virtual-creator-observation" },
    "syntheticOnly": { "const": true },
    "sessionId": { "type": "string", "pattern": "^VC-V0[1-8]-[a-f0-9]{8}(?:-[a-f0-9]{4}){3}-[a-f0-9]{12}$" },
    "profileId": { "type": "string", "pattern": "^V0[1-8]$" },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gitSha", "bundleId", "executableSha256"],
      "properties": {
        "gitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "bundleId": { "const": "com.paintnode.editor.blueprintqa.provider.free" },
        "executableSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "prefixItems": [
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 1 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 2 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 3 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 4 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 5 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 6 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 7 } } }] },
        { "allOf": [{ "$ref": "#/$defs/task" }, { "properties": { "task": { "const": 8 } } }] }
      ],
      "items": false
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "ownerReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedLive", "evidenceReviewed", "decision", "standard", "notes", "reviewedAt"],
      "properties": {
        "observedLive": { "type": "boolean" },
        "evidenceReviewed": { "type": "boolean" },
        "decision": { "enum": ["pending", "accepted", "rejected"] },
        "standard": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" },
        "reviewedAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "allOf": [
        {
          "if": { "properties": { "decision": { "enum": ["accepted", "rejected"] } }, "required": ["decision"] },
          "then": {
            "properties": {
              "observedLive": { "const": true },
              "evidenceReviewed": { "const": true },
              "reviewedAt": { "type": "string", "format": "date-time" }
            }
          },
          "else": { "properties": { "reviewedAt": { "const": null } } }
        }
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "outcome", "elapsedWallMs", "interventionIds", "frictionFlags", "uiEvidence", "notes"],
      "properties": {
        "task": { "type": "integer", "minimum": 1, "maximum": 8 },
        "outcome": { "enum": ["not-run", "completed-unaided", "completed-assisted", "failed"] },
        "elapsedWallMs": { "type": ["integer", "null"], "minimum": 0 },
        "interventionIds": { "type": "array", "items": { "type": "string", "pattern": "^T[1-8]-C[1-9][0-9]*-(?:H[12]|TO)$" }, "uniqueItems": true },
        "frictionFlags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["discovery", "label-ambiguity", "state-ambiguity", "navigation", "error-comprehension", "recovery-scope", "keyboard-focus", "performance"] }
        },
        "uiEvidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "task", "category", "impact", "evidenceRefs", "interpretation", "requiresHumanValidation"],
      "properties": {
        "id": { "type": "string", "pattern": "^VCF-[1-9][0-9]*$" },
        "task": { "type": "integer", "minimum": 1, "maximum": 8 },
        "category": { "enum": ["data-integrity", "wrong-lineage", "accepted-direction", "editor-return", "save-reopen", "keyboard-accessibility", "critical-task-impossible", "required-input-comprehension", "copy-clarity", "navigation-discovery", "recovery-clarity", "repeated-error-burden", "performance"] },
        "impact": { "enum": ["hypothesis-high", "hypothesis-medium", "hypothesis-low", "observation"] },
        "evidenceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "interpretation": { "type": "string", "minLength": 1 },
        "requiresHumanValidation": { "const": true }
      }
    }
  }
}
